# Python caches/build artifacts
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Local editor/session metadata (저장소에 포함할 Cursor 프로젝트 훅은 예외)
.cursor/*
!.cursor/hooks.json
!.cursor/hooks/
!.cursor/hooks/**
.cursor/hooks/__pycache__/
.vscode/

# Runtime trading data and logs — CSV·주문로그는 개인/계좌 정보 위험으로 제외,
# 학습 산출물(pkl)만 필요 시 버전 관리(공개 저장소면 민감 정보 없는지 확인).
data/*
!data/ai_buy_model.pkl
*.log
*.csv
scan_picks_*.json
scan_picks_*.jsonl
waiting_status_log.csv

# Local backups and shortcuts
backup_old_*/
*.bak
*.lnk

# Local notes that may contain private operational details
*.txt
